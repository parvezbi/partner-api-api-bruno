meta {
  name: Hotspot Payment Details
  type: http
  seq: 4
}

post {
  url: {{base_url}}/partner/customer/hotspot/payment/details
  body: json
  auth: bearer
}

auth:bearer {
  token: 212070|QAaneUqi1nJYhVJ5BsNgQxF9BRPjpZ8TniQGlqbc
}

body:json {
  {
    "uid": 190297,
    "package_id": 5,
    "package_type": "wifi",
    "connection_media": "fiber",
    "user_type": "individual",
    "ip_type": "dynamic",
    "billing_cycle": "fixed_date",
    "payment_method": "bkash",
    "billing_start_date": "2026-07-23",
