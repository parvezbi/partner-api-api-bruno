meta {
  name: Broadband Payment Create
  type: http
  seq: 5
}

post {
  url: {{base_url}}/partner/customer/broadband/payment/create
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "zone_id": 8221080,
    "uid": 190297,
    "mobile_number": "01314351680",
    "payable_amount": 762.1,
    "package": "Freelancer",
    "cache_key": "broadband_payment_190297"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

example {
  name: success-dev
  
  request: {
    url: {{base_url}}/partner/customer/broadband/payment/create
