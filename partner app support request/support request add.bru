meta {
  name: support request add
  type: http
  seq: 6
}

post {
  url: {{base_url}}/partner/support/request
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  subject: Network Problem
  category: network
  description: Network is too much slow
  priority: urgent
  attachment: @file(F:\Alamin\afrin-shahana.pdf) @contentType(application/pdf)
}

settings {
  encodeUrl: true
  timeout: 0
}

example {
  name: success-dev
  
  request: {
    url: {{base_url}}/partner/support/request
    method: POST
    mode: multipartForm
    body:multipart-form: {
      subject: Network Problem
      category: network
      description: Network is too much slow
      priority: urgent
      attachment: @file(F:\Alamin\afrin-shahana.pdf) @contentType(application/pdf)
    }
  }
  
  response: {
    headers: {
      date: Mon, 20 Jul 2026 06:55:26 GMT
      server: Apache/2.4.59 (Debian)
      vary: Authorization,Origin
      cache-control: no-cache, private
      x-ratelimit-limit: 200
      x-ratelimit-remaining: 199
      keep-alive: timeout=5, max=100
      connection: Keep-Alive
      transfer-encoding: chunked
      content-type: application/json
    }
  
    status: {
      code: 201
      text: Created
    }
  
    body: {
      type: json
      content: '''
        {
          "success": true,
          "message": "Support request created successfully",
          "data": {
