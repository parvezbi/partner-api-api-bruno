            "attachment": "support/attachments/afrin-shahana_1784530526_6a5dc65e80ce3.pdf",
            "attachment_url": "https://nmsbackend.acloudplanet.com/storage/support/attachments/afrin-shahana_1784530526_6a5dc65e80ce3.pdf",
            "created_at": "2026-07-20T06:55:26.000000Z"
          }
