meta {
  name: Show Notice
  type: http
  seq: 6
}

get {
  url: {{base_url}}/partner/notices/show?id=1
  body: multipartForm
  auth: bearer
}

params:query {
  id: 1
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  ~id: 1
}

settings {
  encodeUrl: true
  timeout: 0
}

