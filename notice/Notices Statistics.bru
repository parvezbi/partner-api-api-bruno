meta {
  name: Notices Statistics
  type: http
  seq: 2
}

get {
  url: {{base_url}}/partner/notices/statistics
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

example {
  name: success-dev
  
  request: {
    url: {{base_url}}/partner/notices/statistics
    method: GET
    mode: none
  }
  
  response: {
    headers: {
      date: Thu, 09 Jul 2026 12:15:56 GMT
      server: Apache/2.4.59 (Debian)
      vary: Authorization,Origin
      cache-control: no-cache, private
      x-ratelimit-limit: 200
      x-ratelimit-remaining: 199
      keep-alive: timeout=5, max=100
      connection: Keep-Alive
      transfer-encoding: chunked
      content-type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "results": {
            "total": 0,
            "active": 0,
            "inactive": 0,
            "published_today": 0,
            "expired": 0,
            "type_wise": []
          },
          "status": "success",
          "error_type": "",
          "message": "Statistics retrieved successfully",
          "message_en": "Statistics retrieved successfully",
          "message_bn": "পরিসংখ্যান সফলভাবে প্রাপ্ত হয়েছে"
        }
      '''
    }
  }
}

